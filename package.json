{
  "name": "scrapyard-steal",
  "version": "0.1.0",
  "private": true,
  "description": "Multiplayer clicker/strategy game for Gamedev.js Jam 2026",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "ts-node server/index.ts",
    "server:dev": "nodemon --exec ts-node server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "colyseus.js": "^0.15.0",
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "@colyseus/monitor": "^0.15.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "colyseus": "^0.15.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
