{
  "name": "scrapyard-steal",
  "version": "0.5.0",
  "private": true,
  "description": "Multiplayer clicker/strategy game for Gamedev.js Jam 2026",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:prod": "VITE_SERVER_URL=wss://us-ord-ef0ec457.colyseus.cloud vite build && cd dist && zip -r ../dist.zip . && cd ..",
    "preview": "vite preview",
    "server": "ts-node --project tsconfig.server.json server/index.ts",
    "server:dev": "nodemon --exec \"ts-node --project tsconfig.server.json\" server/index.ts",
    "server:build": "tsc --project tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@colyseus/monitor": "^0.15.0",
    "@colyseus/tools": "^0.15.49",
    "colyseus": "^0.15.57",
    "colyseus.js": "^0.15.28",
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "fast-check": "^4.6.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
