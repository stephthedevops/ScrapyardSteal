{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": "server",
    "lib": ["ES2020"]
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules"]
}
